# ============================================================
# .editorconfig -- VBServerInventory module
# Enforces UTF-8 with BOM and CRLF for all .ps1 files
# Required by VB coding standards
# ============================================================
root = true

[*.ps1]
charset                  = utf-8-bom
end_of_line              = crlf
indent_style             = space
indent_size              = 4
trim_trailing_whitespace = true
insert_final_newline     = true

[*.psd1]
charset                  = utf-8-bom
end_of_line              = crlf
indent_style             = space
indent_size              = 4
trim_trailing_whitespace = true
insert_final_newline     = true

[*.psm1]
charset                  = utf-8-bom
end_of_line              = crlf
indent_style             = space
indent_size              = 4
trim_trailing_whitespace = true
insert_final_newline     = true
